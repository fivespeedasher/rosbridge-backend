<launch>
  <!--
    Launch file for ros_web_bridge package
    Starts rosbridge_server WebSocket server, web_video_server, bag playback node,
    lidar filter node, and camera-frame detection node.
  -->

  <!-- Start rosbridge_server WebSocket server -->
  <node name="rosbridge_websocket"
        pkg="rosbridge_server"
        type="rosbridge_websocket"
        output="screen"
        respawn="false">
    <param name="port" value="9092"/>
    <param name="address" value=""/>
    <param name="ssl" value="false"/>
    <param name="authenticate" value="false"/>
    <!-- Prevent unbounded buffer growth for large PointCloud2 messages -->
    <param name="max_message_size" value="10485760"/>  <!-- 10 MB cap -->
    <param name="fragment_timeout" value="60"/>
  </node>

  <!-- Start web_video_server for MJPEG image streaming -->
  <node name="web_video_server"
        pkg="web_video_server"
        type="web_video_server"
        output="screen"
        respawn="false">
    <param name="port" value="9093"/>
    <param name="address" value="0.0.0.0"/>
    <param name="server_threads" value="4"/>
    <param name="default_stream_type" value="h264"/>
  </node>

  <!-- Start our custom ros_web_bridge node -->
  <node name="ros_web_bridge_node"
        pkg="ros_web_bridge"
        type="ros_web_bridge_node"
        output="screen"
        respawn="false">
    <param name="bag_path" value="/home/robot/data/calib/lidar_vision_ip2/lvdata_2026-05-11-15-54-05.bag"/>
  </node>

  <!--
    Lidar filter: /livox/lidar -> /livox/filtered
    (VoxelGrid, RANSAC ground removal, x>0 filter, detections loading).
    The frontend subscribes/unsubscribes to /livox/filtered via the checkbox.
  -->
  <include file="$(find ros_web_bridge)/launch/filter.launch"/>

  <!--
    Camera-frame detection: /livox/filtered -> /livox/inbox_voxel + /camera/frame/points
    Projects to pixel coords, queries detection bboxes, extracts clusters.
    The frontend subscribes/unsubscribes to /livox/inbox_voxel via the checkbox.
  -->
  <include file="$(find ros_web_bridge)/launch/detection.launch"/>

</launch>
